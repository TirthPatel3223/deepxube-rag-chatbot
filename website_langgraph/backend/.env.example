# ============================================================================
# DeepXube RAG Chatbot - Environment Variables
# ============================================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
# ============================================================================

# --- API Keys (REQUIRED) ---
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Model Configuration ---
# Embedding model (OpenAI only, no fallback)
EMBEDDING_MODEL=text-embedding-3-small

# LLM models (primary = OpenAI, fallback = Claude)
LLM_MODEL_PRIMARY=gpt-4o-mini
LLM_MODEL_FALLBACK=claude-haiku-4-5-20241022

# --- Paths (relative to backend/ directory) ---
# Path to the deepxube-main/docs/ directory containing function/class .md files
CODE_DOCS_PATH=../../deepxube-main/docs
# Path to the Research_Papers/ directory containing PDFs
PAPERS_PATH=../../Research_Papers
# Path to the context_files/ directory (ADDING_NEW_DOMAIN.md, etc.)
CONTEXT_FILES_PATH=../../deepxube-main/docs/context_files
# Path to graph.json
GRAPH_JSON_PATH=../../deepxube-main/docs/graph.json
# ChromaDB persistent storage directory
CHROMA_PERSIST_DIR=./data/chromadb

# --- Thresholds ---
FAQ_SIM_THRESHOLD_HIGH=0.92
FAQ_SIM_THRESHOLD_BORDERLINE=0.78
SCOPE_GUARD_THRESHOLD=0.30

# --- Rate Limiting ---
RATE_LIMIT=10/minute

# --- Memory ---
ROLLING_SUMMARY_MAX_TOKENS=200
SESSION_TIMEOUT_MINUTES=30

# --- Server ---
HOST=0.0.0.0
PORT=8000
